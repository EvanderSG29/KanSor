APP_NAME=KanSor
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

KANSOR_API_URL=
KANSOR_ADMIN_EMAIL=
KANSOR_ADMIN_PASSWORD=
KANSOR_LEGACY_SPREADSHEET_ID=
KANSOR_TIMEOUT=20
KANSOR_CONNECT_TIMEOUT=10
KANSOR_SYNC_INTERVAL_SECONDS=60
KANSOR_TOKEN_CACHE_KEY=
KANSOR_DEVICE_LABEL=KanSor Desktop
KANSOR_OFFLINE_LOGIN_DAYS=30
KANSOR_OFFLINE_LOGIN_DAYS_MAX=30
